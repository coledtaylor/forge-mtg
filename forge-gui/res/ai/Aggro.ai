# Aggro AI Profile — creature-based aggression, offense-first

# Mulligan aggressively to find early threats
MULLIGAN_THRESHOLD=3

# Attack preferences — all-out aggression with creature trades
PLAY_AGGRO=true
CHANCE_TO_ATTACK_INTO_TRADE=100
ATTACK_INTO_TRADE_WHEN_TAPPED_OUT=true
RANDOMLY_ATKTRADE_ONLY_ON_LOWER_LIFE_PRESSURE=false
CHANCE_TO_ATKTRADE_WHEN_OPP_HAS_MANA=80
USE_BERSERK_AGGRESSIVELY=true
TRY_TO_HOLD_COMBAT_TRICKS_UNTIL_BLOCK=true

# Blocking preferences — be stingy about trading creatures on defense
# Aggro wants to keep creatures alive for offense, not throw them away blocking
ENABLE_RANDOM_FAVORABLE_TRADES_ON_BLOCK=true
MIN_CHANCE_TO_RANDOMLY_TRADE_ON_BLOCK=0
MAX_CHANCE_TO_RANDOMLY_TRADE_ON_BLOCK=30
ALSO_TRADE_WHEN_HAVE_A_REPLACEMENT_CREAT=false

# Equipment — always move to the best attacker
MOVE_EQUIPMENT_TO_BETTER_CREATURES=always

# Land and mana — don't sit on mana, dump it early
HOLD_LAND_DROP_FOR_MAIN2_IF_UNUSED=30

# Flash — use flash creatures as blockers when needed, but primarily stay on offense
FLASH_CHANCE_TO_CAST_AS_VALUABLE_BLOCKER=100

# Spell preferences — don't bother recycling, maximize offensive output
TRY_TO_PRESERVE_BUYBACK_SPELLS=false

# Scry — low CMC creatures are exactly what aggro wants, keep them
SCRY_EVALTHR_CMC_THRESHOLD=1
