# Combo AI Profile — preserve hand resources, avoid combat, enable spell chaining

# Mulligan aggressively to find combo pieces
MULLIGAN_THRESHOLD=3

# Attack preferences — avoid combat entirely, protect combo pieces
PLAY_AGGRO=false
CHANCE_TO_ATTACK_INTO_TRADE=0
ATTACK_INTO_TRADE_WHEN_TAPPED_OUT=false
TRY_TO_AVOID_ATTACKING_INTO_CERTAIN_BLOCK=true
RANDOMLY_ATKTRADE_ONLY_ON_LOWER_LIFE_PRESSURE=true
CHANCE_TO_ATKTRADE_WHEN_OPP_HAS_MANA=0
USE_BERSERK_AGGRESSIVELY=false

# Blocking preferences — very reluctant to trade, creatures are often combo pieces
ENABLE_RANDOM_FAVORABLE_TRADES_ON_BLOCK=true
MIN_CHANCE_TO_RANDOMLY_TRADE_ON_BLOCK=0
MAX_CHANCE_TO_RANDOMLY_TRADE_ON_BLOCK=25
ALSO_TRADE_WHEN_HAVE_A_REPLACEMENT_CREAT=false
RANDOMLY_TRADE_EVEN_WHEN_HAVE_LESS_CREATS=false

# Spell preservation — never waste spells; combo needs every piece
TRY_TO_PRESERVE_BUYBACK_SPELLS=true
CHANCE_TO_CHAIN_TWO_DAMAGE_SPELLS=0

# Storm spell logic — be storm-aware: fire spells when count is high
PRIORITY_REDUCTION_FOR_STORM_SPELLS=0
MIN_COUNT_FOR_STORM_SPELLS=2

# Land and mana — hold mana for combo windows
HOLD_LAND_DROP_FOR_MAIN2_IF_UNUSED=100

# Flash — hold spells for optimal timing in the combo sequence
FLASH_ENABLE_ADVANCED_LOGIC=true
FLASH_CHANCE_TO_CAST_FOR_ETB_BEFORE_MAIN1=5

# Scry — keep combo pieces even if not immediately castable
SCRY_IMMEDIATELY_UNCASTABLE_TO_BOTTOM=false

# Energy — only commit energy during combat, not proactively
CONSERVATIVE_ENERGY_PAYMENT_ONLY_IN_COMBAT=true
