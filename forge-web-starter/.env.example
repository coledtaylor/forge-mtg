# ============================================
# Docker Compose Environment Variables
# ============================================
# The .env file is automatically loaded by docker-compose
# Copy this file to .env and customize for your setup

# ============================================
# PostgreSQL Configuration
# ============================================
# Used by docker-compose.yml for the postgres service
POSTGRES_DB=forge
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_PORT=5432

# ============================================
# Spring Boot App Configuration
# ============================================
# Used by application.yml for database connection
DATABASE_URL=jdbc:postgresql://localhost:5432/forge
DATABASE_USER=forge
DATABASE_PASSWORD=forge

# ============================================
# Redis Configuration (Optional)
# ============================================
# Used for caching if spring.cache.type=redis
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# pgAdmin Configuration (Optional)
# ============================================
# Web interface for PostgreSQL at http://localhost:5050
PGADMIN_EMAIL=admin@forge.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ============================================
# Forge Card Import Configuration
# ============================================
# Path to Forge cardsfolder (relative to forge-web-starter directory)
FORGE_CARDS_FOLDER=../forge-gui/res/cardsfolder

# Set to true to import cards on application startup
IMPORT_CARDS=false

# ============================================
# Notes
# ============================================
# - When running app locally: DATABASE_URL uses 'localhost'
# - When running in Docker: Use service names (e.g., 'postgres')
# - Set IMPORT_CARDS=true to run the comprehensive card importer
# - Importer will process all .txt files in FORGE_CARDS_FOLDER
# - Default batch size: 1000 cards (configured in application.yml)
